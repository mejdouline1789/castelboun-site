export default async function handler(req, context) {
  if (req.method === 'OPTIONS') return new Response(null, { headers: {'Access-Control-Allow-Origin':'*','Access-Control-Allow-Methods':'POST','Access-Control-Allow-Headers':'Content-Type'} });
  if (req.method !== 'POST') return new Response('Method not allowed', { status: 405 });

  let body;
  try { body = await req.json(); } catch { return new Response('JSON invalide', { status: 400 }); }

  const RESEND_API_KEY = process.env.RESEND_API_KEY;
  if (!RESEND_API_KEY) return new Response('Clé API manquante', { status: 500 });

  const { participants = [], evenement, dateArrivee, dateDepart, activites, autreIdee, message } = body;

  const participantsText = participants.map(p => `• ${p.name || ''}${p.email ? ` <${p.email}>` : ''}`).join('\n');
  const guestEmails = participants.map(p => p.email).filter(Boolean);

  const subject = `✅ Réservation — ${evenement || 'Domaine Castelboun'}`;

  const bodyText = [
    '✅ Votre réservation a bien été prise en compte !',
    '',
    evenement   ? `📅 Événement : ${evenement}` : '',
    dateArrivee ? `🗓️ Arrivée : ${dateArrivee}` : '',
    dateDepart  ? `🗓️ Départ : ${dateDepart}` : '',
    participantsText ? `\n👥 Participant(e)s :\n${participantsText}` : '',
    activites   ? `\n🌿 Activités : ${activites}` : '',
    autreIdee   ? `💡 Autre idée : ${autreIdee}` : '',
    message     ? `\n💬 Message : ${message}` : '',
    '',
    'Nous vous répondons sous 48h pour confirmer votre séjour.',
    '',
    '📆 Pour vous abonner à notre agenda :',
    'https://permaculture-au-castelboun.netlify.app/calendar.ics',
    '',
    'Mejdouline & Guillaume — Domaine Castelboun',
  ].filter(l => l !== undefined).join('\n');

  // Destinataires : propriétaires + invités
  const owners = ['diboun.mejdouline@gmail.com', 'castelbou.guillaume@gmail.com'];
  const allTo = [...new Set([...guestEmails, ...owners])];

  // Resend : FROM doit être un domaine vérifié ou onboarding@resend.dev (compte gratuit)
  const FROM = 'Domaine Castelboun <onboarding@resend.dev>';

  const results = await Promise.allSettled(
    allTo.map(to =>
      fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${RESEND_API_KEY}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ from: FROM, to, subject, text: bodyText, reply_to: 'diboun.mejdouline@gmail.com' }),
      }).then(r => r.json())
    )
  );

  const errors = results.filter(r => r.status === 'rejected' || r.value?.error);
  return Response.json({ ok: errors.length === 0, sent: allTo.length, errors: errors.map(e => e.reason || e.value?.error) });
}

export const config = { path: '/api/send-reservation' };
